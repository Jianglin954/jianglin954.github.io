---
layout: default
---
<div class="post">
  <header class="post-header">
    <div class="d-flex flex-wrap align-items-start">
      {% if page.profile and page.profile.image %}
        <div class="profile mr-4 mb-3" style="flex: 0 0 180px; max-width: 180px; margin-top: 0.5rem;">
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 180px, 95vw{% endcapture %}
          {%
            include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image
            cache_bust=true
          %}
        </div>
      {% endif %}

      <div class="about-main" style="flex: 1 1 0; min-width: 0;">
        <h1 class="post-title mb-2">
          {% if site.title == 'blank' %}
            <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>

        {% if page.subtitle %}
          <p class="desc mb-2">{{ page.subtitle }}</p>
        {% endif %}

        <div class="contact-icons mb-3">
          {% social_links %}
          <a
            href="https://huggingface.co/Johnny050407"
            title="Hugging Face"
            aria-label="Hugging Face"
            target="_blank"
            rel="noopener"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <circle
                cx="12"
                cy="12"
                r="8"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
              />
              <circle cx="9" cy="10" r="0.7" fill="currentColor" />
              <circle cx="15" cy="10" r="0.7" fill="currentColor" />
              <path
                d="M9.5 14c.7.9 1.6 1.4 2.5 1.4s1.8-.5 2.5-1.4"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
              />
            </svg>
          </a>
          <a id="WeChatBtn" href="javascript:void(0)" title="WeChat" aria-label="WeChat">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path
                d="M8.5 3C5.5 3 3 5.2 3 8c0 1.8 1 3.3 2.6 4.3L5 16l3.1-1.6c.8.2 1.6.3 2.4.3 3 0 5.5-2.2 5.5-5s-2.5-4.7-5.5-4.7H8.5zm-1 3.7a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm3.8 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"
              />
              <path
                d="M16.5 10.3c2.9 0 5.2 2 5.2 4.7 0 1.6-.8 2.9-2.1 3.7l.4 2.3-2.7-1.4c-.4.1-.8.2-1.3.2-.7 0-1.4-.1-2-.3.1-.4.1-.8.1-1.2 0-2.8-2.1-5.1-4.7-5.8 0-.1 0-.1 0-.2 0-1.9 1.8-3.4 4-3.4h3.1z"
              />
            </svg>
          </a>
        </div>

        <div class="about-bio">{{ content }}</div>
      </div>
    </div>
    {% if page.extra_note %}
      <div class="about-extra">{{ page.extra_note }}</div>
    {% endif %}
  </header>

  <article>
    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">Latest Posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2 class="selected-publications-title">
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>

  <div class="flag-counter text-center mt-5 mb-2">
    <a href="https://info.flagcounter.com/bXN6">
      <img
        src="https://s05.flagcounter.com/count2/bXN6/bg_FFFFFF/txt_000000/border_CCCCCC/columns_8/maxflags_12/viewers_0/labels_1/pageviews_1/flags_0/percent_0/"
        alt="Flag Counter"
        border="0"
      >
    </a>
  </div>

  <div id="WeChatMod" class="wechat-modal">
    <div class="wechat-modal-content">
      <div class="wechat-modal-card">
        <button type="button" class="wechat-modal-close" aria-label="Close WeChat QR code">
          &times;
        </button>
        {% if page.wechat_qr %}
          <img src="{{ '/assets/img/' | append: page.wechat_qr | relative_url }}" alt="WeChat QR code">
        {% else %}
          <p>Please add your WeChat QR code and set `wechat_qr` in `/_pages/about.md`.</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script defer src="{{ '/assets/js/wechat.js' | relative_url | bust_file_cache }}" type="text/javascript"></script>
